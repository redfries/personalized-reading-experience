# Copy this file to deploy/.env and fill the real values.

# DigitalOcean region. The volume and GPU Droplet must be in the same region.
DO_REGION=nyc2

# GPU size slug. Get exact value with:
# doctl compute size list | grep -i gpu
# Recommended: L40S or RTX 6000 class GPU if available.
DO_SIZE=PASTE_GPU_SIZE_SLUG_HERE

# DigitalOcean AI/ML-ready NVIDIA image slug.
# Verify available images with: doctl compute image list --public | grep -i gpu
DO_IMAGE=gpu-h100x1-base

# SSH key ID or fingerprint from: doctl compute ssh-key list
DO_SSH_KEY=PASTE_SSH_KEY_ID_OR_FINGERPRINT_HERE

# Names used by scripts.
DROPLET_NAME=personalized-reading-gpu
VOLUME_NAME=reading-data
VOLUME_SIZE=100GiB

# Your app repo.
APP_REPO=https://github.com/redfries/personalized-reading-experience.git
APP_BRANCH=main

# Strong model for GPU deployment.
EMBEDDING_MODEL_NAME=Qwen/Qwen3-Embedding-8B

# For a cheaper/smaller test, you can temporarily use:
# EMBEDDING_MODEL_NAME=sentence-transformers/all-mpnet-base-v2
